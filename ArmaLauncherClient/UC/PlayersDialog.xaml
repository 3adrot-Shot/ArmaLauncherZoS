<Window x:Class="ArmaLauncherClient.UC.PlayersDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ArmaLauncherClient.Services"
        Title="Players"
        Width="420"
        Height="800"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    
    <Border Background="#0e1425" CornerRadius="16" SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="0" Opacity="0.5" Color="#000000"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Border Grid.Row="0" Background="#111830" CornerRadius="16,16,0,0" Padding="20,16" MouseLeftButtonDown="Header_MouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel>
                        <TextBlock x:Name="TitleText" Text="{loc:Loc players_title}" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock x:Name="ServerNameText" Text="" FontSize="12" Foreground="#9ca3af" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    
                    <Button Grid.Column="1" Content="✕" Click="CloseButton_Click" 
                            Width="32" Height="32" Background="Transparent" Foreground="#9ca3af" 
                            BorderBrush="Transparent" Cursor="Hand" FontSize="14">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#dc2626"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
            
            <!-- Player Count Badge -->
            <Border Grid.Row="0" Background="#10b981" CornerRadius="12" Padding="12,6" 
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,12,60,0">
                <TextBlock x:Name="PlayerCountText" Text="0" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
            </Border>
            
            <!-- Players List -->
            <Border Grid.Row="1" Margin="16,8,4,8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="PlayersList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1a2744" CornerRadius="10" Padding="15,12" Margin="0,0,14,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Avatar placeholder -->
                                        <!--<Border Background="#2a3f5f" CornerRadius="20" Width="40" Height="40" Margin="0,0,12,0">
                                            <TextBlock Text="👤" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>-->
                                        
                                        <!-- Player name -->
                                        <TextBlock Grid.Column="1" Text="{Binding Username}" FontSize="14" FontWeight="Medium" 
                                                   Foreground="White" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
            
            <!-- Empty state -->
            <StackPanel x:Name="EmptyState" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                <TextBlock Text="🎮" FontSize="48" HorizontalAlignment="Center" Opacity="0.5"/>
                <TextBlock Text="{loc:Loc players_empty}" Foreground="#6b7280" FontSize="14" HorizontalAlignment="Center" Margin="0,12,0,0"/>
            </StackPanel>
            
            <!-- Footer -->
            <Border Grid.Row="2" Background="#111830" CornerRadius="0,0,16,16" Padding="16,14">
                <Button Content="{loc:Loc btn_close}" Click="CloseButton_Click" HorizontalAlignment="Center"
                        Background="#1f2a44" Foreground="#d1d5f9" BorderBrush="Transparent" 
                        Padding="32,10" FontSize="14" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2a3f5f"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Border>
        </Grid>
    </Border>
</Window>


