<Window x:Class="ArmaLauncherClient.UC.ConsoleLogDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ArmaLauncherClient.Services"
        Title="Log Console"
        Width="1000"
        Height="550"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        ResizeMode="CanResizeWithGrip">
    
    <Border Background="#0e1425" CornerRadius="16" SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="0" Opacity="0.5" Color="#000000"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Border Grid.Row="0" Background="#111830" CornerRadius="16,16,0,0" Padding="20,14" MouseLeftButtonDown="Header_MouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="☢️" FontSize="25" Margin="0,0,10,0"/>
                        <TextBlock Text="{loc:Loc console_title}" FontSize="16" FontWeight="SemiBold" Margin="0,6,0,0"  Foreground="White"/>
                        <TextBlock x:Name="LogCountText" Text=" (0)" FontSize="12" Foreground="#6b7280" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </StackPanel>
                    
                    <!-- Auto-scroll toggle -->
                    <CheckBox x:Name="AutoScrollCheckBox" Grid.Column="1" Content="{loc:Loc console_autoscroll}" IsChecked="True"
                              Foreground="#9ca3af" FontSize="12" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    
                    <!-- Clear button -->
                    <Button Grid.Column="2" Content="{loc:Loc btn_clear}" Click="ClearButton_Click"
                            Background="#1f2a44" Foreground="#d1d5f9" BorderBrush="Transparent" 
                            Padding="12,6" FontSize="12" Cursor="Hand" Margin="0,0,12,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2a3f5f"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <!-- Close button -->
                    <Button Grid.Column="3" Content="✕" Click="CloseButton_Click" 
                            Width="32" Height="32" Background="Transparent" Foreground="#9ca3af" 
                            BorderBrush="Transparent" Cursor="Hand" FontSize="14">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#dc2626"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
            
            <!-- Log Content -->
            <Border Grid.Row="1" Margin="16,12,16,12" Background="#0a0e1a" CornerRadius="8" BorderBrush="#1f2a44" BorderThickness="1">
                <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <TextBox x:Name="LogTextBox" 
                             Background="Transparent" 
                             Foreground="#10b981" 
                             FontFamily="Consolas, Courier New" 
                             FontSize="12"
                             IsReadOnly="True"
                             TextWrapping="NoWrap"
                             BorderThickness="0"
                             Padding="12"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Disabled"
                             HorizontalScrollBarVisibility="Disabled"/>
                </ScrollViewer>
            </Border>
            
            <!-- Footer -->
            <Border Grid.Row="2" Background="#111830" CornerRadius="0,0,16,16" Padding="16,12">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="📄 " Foreground="#6b7280" FontSize="11"/>
                        <TextBlock x:Name="LogFilePathText" Text="" Foreground="#6b7280" FontSize="11" TextTrimming="CharacterEllipsis" MaxWidth="500"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="{loc:Loc btn_open_file}" Click="OpenLogFileButton_Click"
                                Background="#1f2a44" Foreground="#d1d5f9" BorderBrush="Transparent" 
                                Padding="14,8" FontSize="12" Cursor="Hand" Margin="0,0,8,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2a3f5f"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="{loc:Loc btn_close}" Click="CloseButton_Click"
                                Background="#1f2a44" Foreground="#d1d5f9" BorderBrush="Transparent" 
                                Padding="20,8" FontSize="12" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2a3f5f"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>


