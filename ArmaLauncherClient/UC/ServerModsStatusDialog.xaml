<Window x:Class="ArmaLauncherClient.UC.ServerModsStatusDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:loc="clr-namespace:ArmaLauncherClient.Services"
    Title="{loc:Loc mods_on_server}"
    Width="700"
    Height="700"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    ShowInTaskbar="False"
    ResizeMode="NoResize">
    
<Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>
</Window.Resources>
    
<Border Background="#0e1425" CornerRadius="16" SnapsToDevicePixels="True">
    <Border.Effect>
        <DropShadowEffect BlurRadius="25" ShadowDepth="0" Opacity="0.5" Color="#000000"/>
    </Border.Effect>
        
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
            
        <!-- Header -->
        <Border Grid.Row="0" Background="#111830" CornerRadius="16,16,0,0" Padding="20,16" MouseLeftButtonDown="Header_MouseDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                    
                <StackPanel>
                    <TextBlock x:Name="TitleText" Text="{loc:Loc server_mods_compat}" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock x:Name="ServerNameText" Text="" FontSize="12" Foreground="#9ca3af" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                    
                <Button Grid.Column="1" Content="✕" Click="CloseButton_Click" 
                        Width="32" Height="32" Background="Transparent" Foreground="#9ca3af" 
                        BorderBrush="Transparent" Cursor="Hand" FontSize="14">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#dc2626"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
        
        <!-- Status Summary -->
        <Border Grid.Row="1" Background="#161f35" Margin="16,8,16,8" CornerRadius="10" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Installed -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock x:Name="InstalledCountText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#22c55e" HorizontalAlignment="Center"/>
                    <TextBlock Text="{loc:Loc mods_installed}" FontSize="11" Foreground="#9ca3af" HorizontalAlignment="Center"/>
                </StackPanel>
                
                <!-- Missing -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock x:Name="MissingCountText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#ef4444" HorizontalAlignment="Center"/>
                    <TextBlock Text="{loc:Loc mods_missing}" FontSize="11" Foreground="#9ca3af" HorizontalAlignment="Center"/>
                </StackPanel>
                
                <!-- Version Mismatch -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock x:Name="MismatchCountText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#f59e0b" HorizontalAlignment="Center"/>
                    <TextBlock Text="{loc:Loc mods_version_ne}" FontSize="11" Foreground="#9ca3af" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
            
        <!-- Mods List -->
        <Border Grid.Row="2" Margin="16,0,4,8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ModsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10" Padding="15,12" Margin="0,0,14,10">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#1a2744"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Missing">
                                                <Setter Property="Background" Value="#2a1a1a"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="VersionMismatch">
                                                <Setter Property="Background" Value="#2a2a1a"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Status Icon -->
                                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="10" VerticalAlignment="Top" Margin="0,0,12,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#22c55e"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Missing">
                                                        <Setter Property="Background" Value="#ef4444"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="MissingCanDownload">
                                                        <Setter Property="Background" Value="#3b82f6"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="VersionMismatch">
                                                        <Setter Property="Background" Value="#f59e0b"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="✓"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Missing">
                                                            <Setter Property="Text" Value="✕"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="MissingCanDownload">
                                                            <Setter Property="Text" Value="📥"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="VersionMismatch">
                                                            <Setter Property="Text" Value="⚠"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <!-- Mod name -->
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="White" TextTrimming="CharacterEllipsis"/>

                                        <!-- Версии для установленных: У вас → Нужно -->
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0" Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVis}}">
                                            <Border CornerRadius="4" Padding="6,2">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#22c55e"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="VersionMismatch">
                                                                <Setter Property="Background" Value="#ef4444"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="11" Foreground="White" FontWeight="Medium">
                                                    <Run Text="{Binding [mods_your_version], Source={x:Static loc:LocalizationManager.Instance}, Mode=OneWay}"/><Run Text="{Binding LocalVersion}"/>
                                                </TextBlock>
                                            </Border>
                                            <TextBlock Text="→" Foreground="#6b7280" FontSize="14" Margin="6,0" VerticalAlignment="Center" FontWeight="Bold"/>
                                            <Border Background="#6366f1" CornerRadius="4" Padding="6,2">
                                                <TextBlock FontSize="11" Foreground="White" FontWeight="Medium">
                                                    <Run Text="{Binding [mods_required_version], Source={x:Static loc:LocalizationManager.Instance}, Mode=OneWay}"/><Run Text="{Binding ServerVersion}"/>
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>

                                        <!-- Версия для неустановленных -->
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsInstalled}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <Border Background="#6366f1" CornerRadius="4" Padding="6,2">
                                                <TextBlock FontSize="11" Foreground="White" FontWeight="Medium">
                                                    <Run Text="{Binding [mods_requires_version], Source={x:Static loc:LocalizationManager.Instance}, Mode=OneWay}"/><Run Text="{Binding ServerVersion}"/>
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>

                                        <!-- Status text -->
                                        <TextBlock FontSize="11" Margin="0,6,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#22c55e"/>
                                                    <Setter Property="Text" Value="{loc:Loc server_mods_status_ok}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Missing">
                                                            <Setter Property="Foreground" Value="#ef4444"/>
                                                            <Setter Property="Text" Value="{loc:Loc server_mods_status_missing}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="MissingCanDownload">
                                                            <Setter Property="Foreground" Value="#3b82f6"/>
                                                            <Setter Property="Text" Value="{loc:Loc server_mods_status_download}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="VersionMismatch">
                                                            <Setter Property="Foreground" Value="#f59e0b"/>
                                                            <Setter Property="Text" Value="{loc:Loc server_mods_status_version}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        
                                        <!-- ModID -->
                                        <TextBlock FontSize="10" Foreground="#4b5563" Margin="0,4,0,0" FontFamily="Consolas">
                                            <Run Text="ID: "/>
                                            <Run Text="{Binding ModId}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    
                                    <!-- Action buttons -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                                        <!-- Verify button (only for installed mods) -->
                                        <Button Click="VerifyModButton_Click" 
                                                Tag="{Binding}"
                                                ToolTip="{loc:Loc server_mods_verify_tooltip}"
                                                Width="40" Height="40" Background="#6366f1" 
                                                BorderBrush="Transparent" Cursor="Hand"
                                                Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVis}}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                        <TextBlock Text="🔍" FontSize="18"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#4f46e5"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <!-- Download button (only for MissingCanDownload) -->
                                        <Button Click="DownloadModButton_Click" 
                                                Tag="{Binding}"
                                                ToolTip="{loc:Loc server_mods_download_tooltip}"
                                                Width="40" Height="40" Background="#3b82f6" 
                                                BorderBrush="Transparent" Cursor="Hand" Margin="8,0,0,0"
                                                Visibility="{Binding CanDownload, Converter={StaticResource BoolToVis}}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                        <TextBlock Text="📥" FontSize="18"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#2563eb"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <!-- Workshop button -->
                                        <Button Click="WorkshopButton_Click" 
                                                Tag="{Binding ModId}"
                                                ToolTip="{loc:Loc mods_open_workshop}"
                                                Width="40" Height="40" Background="#2a3f5f" 
                                                BorderBrush="Transparent" Cursor="Hand" Margin="8,0,0,0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                        <TextBlock Text="🔗" FontSize="18"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#6366f1"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
        
        <!-- Empty state -->
        <StackPanel x:Name="EmptyState" Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
            <TextBlock Text="📦" FontSize="48" HorizontalAlignment="Center" Opacity="0.5"/>
            <TextBlock Text="{loc:Loc mods_no_mods}" Foreground="#6b7280" FontSize="14" HorizontalAlignment="Center" Margin="0,12,0,0"/>
        </StackPanel>
            
        <!-- Footer -->
        <Border Grid.Row="3" Background="#111830" CornerRadius="0,0,16,16" Padding="16,14">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText" Text="" Foreground="#9ca3af" FontSize="12"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <!-- Download all missing button -->
                    <Button x:Name="DownloadAllButton" Content="{loc:Loc btn_download_missing}" Click="DownloadAllButton_Click"
                            Background="#3b82f6" Foreground="White" BorderBrush="Transparent" 
                            Padding="16,8" FontSize="13" Cursor="Hand" Margin="0,0,12,0" Visibility="Collapsed">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2563eb"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <Button Content="{loc:Loc btn_close}" Click="CloseButton_Click"
                            Background="#1f2a44" Foreground="#d1d5f9" BorderBrush="Transparent" 
                            Padding="24,8" FontSize="13" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2a3f5f"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Border>
</Window>


