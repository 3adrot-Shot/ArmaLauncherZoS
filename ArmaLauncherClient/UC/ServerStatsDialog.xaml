<Window x:Class="ArmaLauncherClient.UC.ServerStatsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ArmaLauncherClient.Services"
        Title="{loc:Loc stats_online_title}"
        Width="900"
        Height="550"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    
    <Border Background="#0e1425" CornerRadius="16" SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="0" Opacity="0.5" Color="#000000"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Border Grid.Row="0" Background="#111830" CornerRadius="16,16,0,0" Padding="20,16" MouseLeftButtonDown="Header_MouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel>
                        <TextBlock Text="{loc:Loc stats_online_title}" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock x:Name="ServerNameText" Text="" FontSize="12" Foreground="#9ca3af" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    
                    <Button Grid.Column="1" Content="✕" Click="CloseButton_Click" 
                            Width="32" Height="32" Background="Transparent" Foreground="#9ca3af" 
                            BorderBrush="Transparent" Cursor="Hand" FontSize="14">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#dc2626"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
            
            <!-- Stats badges -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,12,60,0">
                <Border Background="#6366f1" CornerRadius="8" Padding="10,5" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Max: " FontSize="11" Foreground="#d1d5f9"/>
                        <TextBlock x:Name="MaxPlayersText" Text="0" FontSize="11" FontWeight="Bold" Foreground="White"/>
                    </StackPanel>
                </Border>
                <Border Background="#10b981" CornerRadius="8" Padding="10,5">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Avg: " FontSize="11" Foreground="#d1fae5"/>
                        <TextBlock x:Name="AvgPlayersText" Text="0" FontSize="11" FontWeight="Bold" Foreground="White"/>
                    </StackPanel>
                </Border>
            </StackPanel>
            
            <!-- Chart Area -->
            <Border Grid.Row="1" Margin="20,16,20,8" Background="#1a2744" CornerRadius="12">
                <Grid>
                    <!-- Loading state -->
                    <StackPanel x:Name="LoadingState" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="⏳" FontSize="32" HorizontalAlignment="Center" Opacity="0.7"/>
                        <TextBlock Text="{loc:Loc stats_loading}" Foreground="#9ca3af" FontSize="14" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    </StackPanel>
                    
                    <!-- Error state -->
                    <StackPanel x:Name="ErrorState" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                        <TextBlock Text="❌" FontSize="32" HorizontalAlignment="Center" Opacity="0.7"/>
                        <TextBlock Text="{loc:Loc stats_error}" Foreground="#ef4444" FontSize="14" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    </StackPanel>
                    
                    <!-- Chart -->
                    <Grid x:Name="ChartContainer" Visibility="Collapsed" Margin="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="45"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="30"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Y-axis labels -->
                        <Canvas x:Name="YAxisCanvas" Grid.Column="0" Grid.Row="0"/>
                        
                        <!-- Chart canvas with clipping -->
                        <Border Grid.Column="1" Grid.Row="0" ClipToBounds="True">
                            <Grid>
                                <Canvas x:Name="ChartCanvas" 
                                        MouseMove="ChartCanvas_MouseMove" 
                                        MouseLeave="ChartCanvas_MouseLeave"
                                        MouseWheel="ChartCanvas_MouseWheel"
                                        Background="Transparent"/>
                                
                                <!-- Tooltip positioned via Canvas -->
                                <Canvas IsHitTestVisible="False">
                                    <Border x:Name="TooltipBorder"
                                            Background="#F0111830" CornerRadius="8" Padding="12,8" 
                                            Visibility="Collapsed" IsHitTestVisible="False"
                                            MinWidth="120">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.4"/>
                                        </Border.Effect>
                                        <StackPanel>
                                            <TextBlock x:Name="TooltipTime" Text="" Foreground="#9ca3af" FontSize="11"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="{loc:Loc stats_players}" Foreground="#d1d5f9" FontSize="13"/>
                                                <TextBlock x:Name="TooltipPlayers" Text="" Foreground="#10b981" FontSize="13" FontWeight="Bold"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Canvas>
                                
                                <!-- Vertical cursor line -->
                                <Canvas IsHitTestVisible="False">
                                    <Line x:Name="CursorLine"
                                          Stroke="#6366f1" StrokeThickness="1" StrokeDashArray="4,2"
                                          Visibility="Collapsed" IsHitTestVisible="False"/>
                                </Canvas>
                            </Grid>
                        </Border>
                        
                        <!-- X-axis labels -->
                        <Canvas x:Name="XAxisCanvas" Grid.Column="1" Grid.Row="1"/>
                    </Grid>
                </Grid>
            </Border>
            
            <!-- Footer -->
            <Border Grid.Row="2" Background="#111830" CornerRadius="0,0,16,16" Padding="16,14">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="AddressText" Text="" Foreground="#6b7280" FontSize="12"/>
                        <TextBlock Text=" • " Foreground="#4b5563" FontSize="12"/>
                        <TextBlock x:Name="ZoomText" Text="" Foreground="#6b7280" FontSize="12"/>
                        <TextBlock Text=" • " Foreground="#4b5563" FontSize="12"/>
                        <TextBlock Text="{loc:Loc stats_zoom_hint}" Foreground="#4b5563" FontSize="11" FontStyle="Italic"/>
                    </StackPanel>
                    <Button Content="{loc:Loc btn_close}" Click="CloseButton_Click" HorizontalAlignment="Right"
                            Background="#1f2a44" Foreground="#d1d5f9" BorderBrush="Transparent" 
                            Padding="24,8" FontSize="13" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2a3f5f"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>


