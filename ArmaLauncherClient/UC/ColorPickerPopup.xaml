<UserControl x:Class="ArmaLauncherClient.UC.ColorPickerPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:ArmaLauncherClient.Services"
             Width="280">
    
    <Border Background="#151d33" BorderBrush="#2a3352" BorderThickness="1" CornerRadius="10" Padding="12">
        <StackPanel>
            <!-- Предустановленные цвета -->
            <TextBlock Text="{loc:Loc color_quick_select}" Foreground="#9ca3af" FontSize="11" Margin="0,0,0,8"/>
            <WrapPanel x:Name="PresetColors" Margin="0,0,0,12">
                <!-- Будут добавлены программно -->
            </WrapPanel>
            
            <!-- Разделитель -->
            <Border Height="1" Background="#2a3352" Margin="0,0,0,12"/>
            
            <!-- RGB слайдеры -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="R" Foreground="#ef4444" FontWeight="Bold" VerticalAlignment="Center"/>
                <Slider x:Name="RedSlider" Grid.Column="1" Minimum="0" Maximum="255" Value="100" 
                        Margin="8,0" VerticalAlignment="Center" ValueChanged="Slider_ValueChanged"/>
                <TextBlock x:Name="RedValue" Grid.Column="2" Text="100" Foreground="#9ca3af" 
                           FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
            
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="G" Foreground="#10b981" FontWeight="Bold" VerticalAlignment="Center"/>
                <Slider x:Name="GreenSlider" Grid.Column="1" Minimum="0" Maximum="255" Value="100" 
                        Margin="8,0" VerticalAlignment="Center" ValueChanged="Slider_ValueChanged"/>
                <TextBlock x:Name="GreenValue" Grid.Column="2" Text="100" Foreground="#9ca3af" 
                           FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
            
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="B" Foreground="#3b82f6" FontWeight="Bold" VerticalAlignment="Center"/>
                <Slider x:Name="BlueSlider" Grid.Column="1" Minimum="0" Maximum="255" Value="100" 
                        Margin="8,0" VerticalAlignment="Center" ValueChanged="Slider_ValueChanged"/>
                <TextBlock x:Name="BlueValue" Grid.Column="2" Text="100" Foreground="#9ca3af" 
                           FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
            
            <!-- HEX ввод и превью -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="HexInput" Background="#1f2a44" Foreground="#d1d5f9" BorderBrush="#2a3352"
                         Padding="10,8" FontFamily="Consolas" FontSize="13" TextChanged="HexInput_TextChanged"/>
                <Border x:Name="ColorPreview" Grid.Column="1" CornerRadius="6" Margin="8,0,0,0" 
                        BorderBrush="#2a3352" BorderThickness="1"/>
            </Grid>
            
            <!-- Кнопки -->
            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Content="{loc:Loc color_cancel}" Click="Cancel_Click" Margin="0,0,4,0"
                        Background="#2a3352" Foreground="White" BorderBrush="Transparent" Padding="12,8" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3b4f6b"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Grid.Column="1" Content="{loc:Loc color_apply}" Click="Apply_Click" Margin="4,0,0,0"
                        Background="#6366f1" Foreground="White" BorderBrush="Transparent" Padding="12,8" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#4f46e5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
