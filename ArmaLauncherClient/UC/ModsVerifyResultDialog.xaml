<Window x:Class="ArmaLauncherClient.UC.ModsVerifyResultDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ArmaLauncherClient.Services"
        Title="{loc:Loc mods_verify_title}"
        Height="600" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border Background="#0d1424" BorderBrush="#2a3352" BorderThickness="1" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Border Grid.Row="0" Background="#111830" CornerRadius="12,12,0,0" Padding="16,12" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="TitleIcon" Text="🔍" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="TitleText" Text="{loc:Loc mods_verify_title}" FontSize="14" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="✕" Click="Close_Click" 
                            Background="Transparent" Foreground="#9ca3af" BorderBrush="Transparent"
                            Width="28" Height="28" FontSize="14" Cursor="Hand" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#ef4444"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
            
            <!-- Content -->
            <Grid Grid.Row="1" Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Summary Stats -->
                <Border Grid.Row="0" Background="#161f35" CornerRadius="10" Padding="16,12" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock x:Name="ValidCountText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#22c55e" HorizontalAlignment="Center"/>
                            <TextBlock Text="✓ OK" FontSize="11" Foreground="#9ca3af" HorizontalAlignment="Center"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock x:Name="InvalidCountText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#ef4444" HorizontalAlignment="Center"/>
                            <TextBlock Text="{loc:Loc mods_verify_damaged}" FontSize="11" Foreground="#9ca3af" HorizontalAlignment="Center"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock x:Name="NotInstalledCountText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#6b7280" HorizontalAlignment="Center"/>
                            <TextBlock Text="{loc:Loc mods_verify_not_installed}" FontSize="11" Foreground="#9ca3af" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <!-- Select All -->
                <Border Grid.Row="1" Background="#1a2744" CornerRadius="8" Padding="12,8" Margin="0,0,0,12"
                        x:Name="SelectAllBorder" Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="SelectAllCheckbox" Grid.Column="0" VerticalAlignment="Center" 
                                  Checked="SelectAll_Changed" Unchecked="SelectAll_Changed"/>
                        <TextBlock Grid.Column="1" Text="{loc:Loc mods_verify_select_all}" Foreground="White" FontSize="12" 
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                        <TextBlock x:Name="SelectedCountText" Grid.Column="2" Text="" Foreground="#6b7280" FontSize="11" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                
                <!-- Mods List -->
                <Border Grid.Row="2" Background="#111830" CornerRadius="10" Padding="8">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ModsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Padding="12,10" Margin="0,0,0,6">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#1a2744"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Invalid">
                                                        <Setter Property="Background" Value="#2a1a1a"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="NotInstalled">
                                                        <Setter Property="Background" Value="#1a1a1a"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Checkbox (only for invalid mods) -->
                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,10,0"
                                                      Visibility="{Binding CanRepair, Converter={StaticResource BoolToVis}}"
                                                      Checked="ModCheckbox_Changed" Unchecked="ModCheckbox_Changed"/>
                                            
                                            <!-- Status Icon -->
                                            <Border Grid.Column="1" Width="36" Height="36" CornerRadius="8" VerticalAlignment="Top" Margin="0,0,12,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#22c55e"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Invalid">
                                                                <Setter Property="Background" Value="#ef4444"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="NotInstalled">
                                                                <Setter Property="Background" Value="#4b5563"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="✓"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Invalid">
                                                                    <Setter Property="Text" Value="✕"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="NotInstalled">
                                                                    <Setter Property="Text" Value="○"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                            
                                            <!-- Mod Info -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" Foreground="White" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding StatusText}" FontSize="11" Margin="0,4,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#22c55e"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Invalid">
                                                                    <Setter Property="Foreground" Value="#ef4444"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="NotInstalled">
                                                                    <Setter Property="Foreground" Value="#6b7280"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                
                                                <!-- Invalid files details (expandable) -->
                                                <Expander Header="{Binding InvalidFilesHeader}" Margin="0,6,0,0"
                                                          Visibility="{Binding HasInvalidFiles, Converter={StaticResource BoolToVis}}"
                                                          Foreground="#9ca3af" FontSize="10">
                                                    <ItemsControl ItemsSource="{Binding InvalidFiles}" Margin="0,4,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="#161f35" CornerRadius="4" Padding="8,4" Margin="0,0,0,2">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Text="{Binding Icon}" Foreground="{Binding IconColor}" FontSize="10" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                                        <TextBlock Grid.Column="1" Text="{Binding FileName}" Foreground="#9ca3af" FontSize="10" TextTrimming="CharacterEllipsis"/>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Expander>
                                            </StackPanel>
                                            
                                            <!-- Version -->
                                            <Border Grid.Column="3" Background="#3b4f6b" CornerRadius="4" Padding="8,4" VerticalAlignment="Top"
                                                    Visibility="{Binding HasVersion, Converter={StaticResource BoolToVis}}">
                                                <TextBlock FontSize="10" Foreground="#9ca3af">
                                                    <Run Text="v"/><Run Text="{Binding Version}"/>
                                                </TextBlock>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
                
                <!-- Buttons -->
                <Grid Grid.Row="3" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock x:Name="StatusText" Grid.Column="0" Foreground="#6b7280" FontSize="11" VerticalAlignment="Center"/>
                    
                    <Button x:Name="CancelButton" Grid.Column="1" Content="{loc:Loc btn_close}" Click="Cancel_Click"
                            Background="#2a3352" Foreground="White" BorderBrush="Transparent"
                            Padding="20,10" FontSize="13" Cursor="Hand" Margin="0,0,10,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#3b4f6b"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <Button x:Name="RepairButton" Grid.Column="2" Content="{loc:Loc btn_repair}" Click="Repair_Click"
                            Background="#3b82f6" Foreground="White" BorderBrush="Transparent"
                            Padding="20,10" FontSize="13" Cursor="Hand" Visibility="Collapsed">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2563eb"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>


