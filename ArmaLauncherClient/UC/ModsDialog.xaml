<Window x:Class="ArmaLauncherClient.UC.ModsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:loc="clr-namespace:ArmaLauncherClient.Services"
    Title="{loc:Loc mods_on_server}"
    Width="600"
    Height="650"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    ShowInTaskbar="False"
    ResizeMode="NoResize">
    
<Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>
</Window.Resources>
    
<Border Background="#0e1425" CornerRadius="16" SnapsToDevicePixels="True">
    <Border.Effect>
        <DropShadowEffect BlurRadius="25" ShadowDepth="0" Opacity="0.5" Color="#000000"/>
    </Border.Effect>
        
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
            
        <!-- Header -->
        <Border Grid.Row="0" Background="#111830" CornerRadius="16,16,0,0" Padding="20,16" MouseLeftButtonDown="Header_MouseDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                    
                <StackPanel>
                    <TextBlock x:Name="TitleText" Text="{loc:Loc mods_addons_on_server}" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock x:Name="ServerNameText" Text="" FontSize="12" Foreground="#9ca3af" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                    
                <Button Grid.Column="1" Content="✕" Click="CloseButton_Click" 
                        Width="32" Height="32" Background="Transparent" Foreground="#9ca3af" 
                        BorderBrush="Transparent" Cursor="Hand" FontSize="14">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#dc2626"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
            
            <!-- Mods Count Badge -->
            <Border Grid.Row="0" Background="#6366f1" CornerRadius="12" Padding="12,6" 
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,12,60,0">
                <TextBlock x:Name="ModsCountText" Text="0" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
            </Border>
            
            <!-- Mods List -->
            <Border Grid.Row="1" Margin="16,8,4,8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ModsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1a2744" CornerRadius="10" Padding="15,12" Margin="0,0,14,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <!-- Mod name -->
                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" 
                                                       Foreground="White" TextTrimming="CharacterEllipsis"/>
                                            
                                            <!-- Version and size row -->
                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                <Border Background="#22c55e" CornerRadius="4" Padding="6,2">
                                                    <TextBlock Text="{Binding Version}" FontSize="11" Foreground="White" FontWeight="Medium"/>
                                                </Border>
                                                <TextBlock FontSize="11" Foreground="#6b7280" Margin="10,0,0,0" VerticalAlignment="Center">
                                                    <Run Text="{Binding TotalSizeFormatted}"/>
                                                    <Run Text=" • "/>
                                                    <Run Text="{Binding FileCount}"/>
                                                    <Run Text="{Binding [mods_files_suffix], Source={x:Static loc:LocalizationManager.Instance}, Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>
                                            
                                            <!-- ModID -->
                                            <TextBlock FontSize="10" Foreground="#4b5563" Margin="0,6,0,0" FontFamily="Consolas">
                                                <Run Text="ID: "/>
                                                <Run Text="{Binding ModId}"/>
                                            </TextBlock>
                                            
                                            <!-- Dependencies if any -->
                                            <ItemsControl ItemsSource="{Binding Dependencies}" Margin="0,6,0,0"
                                                          Visibility="{Binding HasDependencies, Converter={StaticResource BoolToVis}}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock FontSize="10" Foreground="#f59e0b" Margin="0,2,0,0">
                                                            <Run Text="📎 "/>
                                                            <Run Text="{Binding Name}"/>
                                                            <Run Text=" v"/>
                                                            <Run Text="{Binding Version}"/>
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                        
                                        <!-- Workshop button -->
                                        <Button Grid.Column="1" Click="WorkshopButton_Click" 
                                                Tag="{Binding ModId}"
                                                ToolTip="{loc:Loc mods_open_workshop}"
                                                Width="40" Height="40" Background="#2a3f5f" 
                                                BorderBrush="Transparent" Cursor="Hand" VerticalAlignment="Top">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                        <TextBlock Text="🔗" FontSize="18"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#6366f1"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
            
            <!-- Empty state -->
            <StackPanel x:Name="EmptyState" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                <TextBlock Text="📦" FontSize="48" HorizontalAlignment="Center" Opacity="0.5"/>
                <TextBlock Text="{loc:Loc mods_no_mods}" Foreground="#6b7280" FontSize="14" HorizontalAlignment="Center" Margin="0,12,0,0"/>
            </StackPanel>
            
            <!-- Footer -->
            <Border Grid.Row="2" Background="#111830" CornerRadius="0,0,16,16" Padding="16,14">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="TotalSizeText" Text="" Foreground="#9ca3af" FontSize="12"/>
                    </StackPanel>
                    <Button Content="{loc:Loc btn_close}" Click="CloseButton_Click" HorizontalAlignment="Right"
                            Background="#1f2a44" Foreground="#d1d5f9" BorderBrush="Transparent" 
                            Padding="24,8" FontSize="13" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2a3f5f"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>


