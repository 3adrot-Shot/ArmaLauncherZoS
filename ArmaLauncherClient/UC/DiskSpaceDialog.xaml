<Window x:Class="ArmaLauncherClient.UC.DiskSpaceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ArmaLauncherClient.Services"
        Title="{loc:Loc disk_title}"
        Height="380" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize">
    
    <Border Background="#0d1424" BorderBrush="#ef4444" BorderThickness="1" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Title Bar -->
            <Border Grid.Row="0" Background="#1a1a2e" CornerRadius="12,12,0,0" Padding="20,16" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="❌" FontSize="20" Foreground="#ef4444" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Text="{loc:Loc disk_header}" FontSize="16" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="✕" Click="Close_Click" 
                            Background="Transparent" Foreground="#9ca3af" BorderBrush="Transparent"
                            Width="28" Height="28" FontSize="14" Cursor="Hand" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#ef4444"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
            
            <!-- Content -->
            <Grid Grid.Row="1" Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Иконка и сообщение -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,8,0,20">
                    <Border Background="#2d1f1f" CornerRadius="50" Width="80" Height="80" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <TextBlock Text="💾" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="MessageText" Text="{loc:Loc disk_message}"
                               Foreground="#e5e7eb" FontSize="15" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
                
                <!-- Информация о диске -->
                <Border Grid.Row="1" Background="#151d33" CornerRadius="10" Padding="16" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Text="{loc:Loc disk_label}" Foreground="#9ca3af" FontSize="13"/>
                        <TextBlock x:Name="DriveText" Grid.Column="1" Text="C:" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        
                        <TextBlock Grid.Row="1" Text="{loc:Loc disk_free}" Foreground="#9ca3af" FontSize="13" Margin="0,8,0,0"/>
                        <TextBlock x:Name="FreeSpaceText" Grid.Row="1" Grid.Column="1" Text="0 GB" Foreground="#ef4444" FontSize="13" FontWeight="SemiBold" Margin="0,8,0,0"/>
                        
                        <TextBlock Grid.Row="2" Text="{loc:Loc disk_required}" Foreground="#9ca3af" FontSize="13" Margin="0,8,0,0"/>
                        <TextBlock x:Name="RequiredSpaceText" Grid.Row="2" Grid.Column="1" Text="0 GB" Foreground="#f59e0b" FontSize="13" FontWeight="SemiBold" Margin="0,8,0,0"/>
                    </Grid>
                </Border>
                
                <!-- Рекомендации -->
                <Border Grid.Row="2" Background="#1a2744" CornerRadius="8" Padding="12" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc disk_recommendations}" Foreground="#9ca3af" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="{loc:Loc disk_tip1}" Foreground="#6b7280" FontSize="12"/>
                        <TextBlock Text="{loc:Loc disk_tip2}" Foreground="#6b7280" FontSize="12" Margin="0,4,0,0"/>
                        <TextBlock Text="{loc:Loc disk_tip3}" Foreground="#6b7280" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- Кнопки -->
                <Grid Grid.Row="3" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="1" Content="{loc:Loc btn_settings}" Click="OpenSettings_Click"
                            Background="#2a3352" Foreground="White" BorderBrush="Transparent"
                            Padding="18,12" Margin="0,0,12,0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#3b4f6b"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <Button Grid.Column="2" Content="OK" Click="Ok_Click"
                            Background="#ef4444" Foreground="White" BorderBrush="Transparent"
                            Padding="32,12" Cursor="Hand" FontWeight="SemiBold">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#dc2626"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>


