<Window x:Class="ArmaLauncherClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ArmaLauncherClient"
        xmlns:vm="clr-namespace:ArmaLauncherClient.ViewModels"
        xmlns:conv="clr-namespace:ArmaLauncherClient.Converters"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="Arma Launcher" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a2e">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
        <conv:StringToVisibilityConverter x:Key="StringToVisibility"/>
        
        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Background" Value="#6366f1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#818cf8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#4b5563"/>
                                <Setter Property="Foreground" Value="#9ca3af"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style TargetType="Button" x:Key="SecondaryButton" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#374151"/>
        </Style>
        
        <Style TargetType="Button" x:Key="DangerButton" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#dc2626"/>
        </Style>
        
        <Style TargetType="Button" x:Key="SmallButton" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="#16213e" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel>
                    <TextBlock Text="Arma Launcher" FontSize="28" FontWeight="Bold" Foreground="White"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Server: " Foreground="#6b7280" FontSize="14" VerticalAlignment="Center"/>
                        <ComboBox ItemsSource="{Binding AvailableServers}"
                                  SelectedItem="{Binding SelectedServer}"
                                  IsEnabled="{Binding IsDownloading, Converter={StaticResource InverseBool}}"
                                  MinWidth="280"
                                  Background="#374151"
                                  Foreground="Black"
                                  BorderThickness="0"
                                  Padding="10,6"
                                  FontSize="13" SelectionChanged="ComboBox_SelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                        <TextBlock Text=" - " Foreground="#6b7280"/>
                                        <TextBlock Text="{Binding Url}" Foreground="#10b981"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Download Mode Selector -->
                    <TextBlock Text="Mode:" Foreground="#6b7280" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox ItemsSource="{Binding AvailableDownloadModes}"
                              SelectedItem="{Binding DownloadMode}"
                              IsEnabled="{Binding IsDownloading, Converter={StaticResource InverseBool}}"
                              MinWidth="120"
                              Background="#374151"
                              Foreground="Black"
                              BorderThickness="0"
                              Padding="8,4"
                              FontSize="12"
                              Margin="0,0,15,0"
                              ToolTip="Phased = Max speed, more RAM. Streaming = Less RAM, direct write."/>
                    
                    <Button Content="⚡ SpeedTest" Style="{StaticResource SmallButton}" 
                            Click="SpeedTestButton_Click" Margin="0,0,10,0"
                            ToolTip="Проверить скорость соединения с сервером"
                            IsEnabled="{Binding IsDownloading, Converter={StaticResource InverseBool}}"/>
                    <Button Content="🔧 Диагностика" Style="{StaticResource SmallButton}" 
                            Click="DiagnosticsButton_Click" Margin="0,0,10,0"
                            ToolTip="Запустить диагностику системы"/>
                    <Button Content="⟳ Refresh" Style="{StaticResource SecondaryButton}" 
                            Click="RefreshButton_Click" Margin="0,0,10,0"
                            IsEnabled="{Binding IsDownloading, Converter={StaticResource InverseBool}}"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Loading Indicator -->
        <Border Grid.Row="1" Background="#1a1a2e" 
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                Panel.ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Loading..." FontSize="24" Foreground="White"/>
            </StackPanel>
        </Border>
        
        <!-- Model List -->
        <ScrollViewer Grid.Row="1" Padding="20" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Models}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#16213e" CornerRadius="12" Margin="0,0,0,15" Padding="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayName}" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                                    
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <Border Background="#374151" CornerRadius="4" Padding="8,4" Margin="0,0,10,0">
                                            <TextBlock Text="{Binding StatusText}" Foreground="#9ca3af" FontSize="12"/>
                                        </Border>
                                        
                                        <Border Background="#f59e0b" CornerRadius="4" Padding="8,4" Margin="0,0,10,0"
                                                Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="Update Available" Foreground="White" FontSize="12"/>
                                        </Border>
                                        
                                        <TextBlock Text="{Binding SizeFormatted}" Foreground="#6b7280" VerticalAlignment="Center"/>
                                        <TextBlock Text=" • " Foreground="#6b7280" VerticalAlignment="Center"/>
                                        <TextBlock Foreground="#6b7280" VerticalAlignment="Center">
                                            <Run Text="{Binding FileCount, Mode=OneWay}"/>
                                            <Run Text=" files"/>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="📥 Install" Style="{StaticResource PrimaryButton}"
                                            Click="InstallButton_Click" Tag="{Binding}"
                                            Margin="0,0,10,0"/>
                                    
                                    <Button Content="✓ Verify" Style="{StaticResource SecondaryButton}"
                                            Click="VerifyButton_Click" Tag="{Binding}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        
        <!-- Progress Section -->
        <Border Grid.Row="2" Background="#16213e" Padding="20"
                Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Download info -->
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding DownloadPercent, StringFormat='{}{0:F1}%'}" 
                                       FontSize="20" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text=" • " Foreground="#6b7280" FontSize="20" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding DownloadedSize}" Foreground="#9ca3af" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text=" / " Foreground="#6b7280" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalSize}" Foreground="#9ca3af" FontSize="16" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock Text="{Binding DownloadSpeed}" Foreground="#10b981" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Text=" • " Foreground="#6b7280" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Foreground="#f59e0b" FontSize="14">
                                <Run Text="ETA: "/><Run Text="{Binding Eta, Mode=OneWay}"/>
                            </TextBlock>
                            <TextBlock Text=" • " Foreground="#6b7280" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding FileProgress}" Foreground="#9ca3af" FontSize="14"/>
                            <TextBlock Text=" • " Foreground="#6b7280" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding CurrentFileName}" Foreground="#6b7280" FontSize="14" 
                                       MaxWidth="300" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <Button Grid.Column="1" Content="✕ Cancel" Style="{StaticResource DangerButton}" 
                            Click="CancelButton_Click" VerticalAlignment="Center"/>
                </Grid>
                
                <ProgressBar Height="10" Value="{Binding DownloadPercent}" Maximum="100"
                             Background="#374151" Foreground="#6366f1" BorderThickness="0"/>
            </StackPanel>
        </Border>
        
        <!-- Status Bar with SpeedTest result -->
        <Border Grid.Row="3" Background="#0f0f23" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="{Binding StatusMessage}" Foreground="#9ca3af" VerticalAlignment="Center"/>
                
                <TextBlock Grid.Column="1" Text="{Binding SpeedTestResult}" Foreground="#10b981" 
                           VerticalAlignment="Center" Margin="20,0,0,0"
                           Visibility="{Binding SpeedTestResult, Converter={StaticResource StringToVisibility}}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
